generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  API
  RSS
  CSV
  JSON
}

enum JobType {
  INGEST
  NORMALIZE
  ENRICH
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum RecordStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Source {
  id          String      @id @default(uuid())
  name        String
  type        SourceType
  config      Json
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  checkpoints SourceCheckpoint[]
  rawRecords  RawRecord[]

  @@index([isActive])
  @@index([type])
}

model SourceCheckpoint {
  id            String    @id @default(uuid())
  sourceId      String
  source        Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cursor        String?
  lastFetchedAt DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([sourceId])
  @@index([sourceId])
}

model RawRecord {
  id          String    @id @default(uuid())
  sourceId    String
  source      Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId  String
  payload     Json
  hash        String
  createdAt   DateTime  @default(now())
  normalized  NormalizedRecord?

  @@unique([sourceId, externalId])
  @@index([hash])
  @@index([sourceId])
  @@index([createdAt])
}

model NormalizedRecord {
  id             String        @id @default(uuid())
  rawRecordId    String        @unique
  rawRecord      RawRecord     @relation(fields: [rawRecordId], references: [id], onDelete: Cascade)
  structuredData Json
  status         RecordStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  enriched       EnrichedRecord?

  @@index([status])
  @@index([createdAt])
}

model EnrichedRecord {
  id             String        @id @default(uuid())
  normalizedRecordId String      @unique
  normalized     NormalizedRecord @relation(fields: [normalizedRecordId], references: [id], onDelete: Cascade)
  enrichedData   Json
  status         RecordStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
}

model PipelineJob {
  id          String     @id @default(uuid())
  type        JobType
  status      JobStatus  @default(PENDING)
  retries     Int        @default(0)
  maxRetries  Int        @default(3)
  scheduledAt DateTime   @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  payload     Json
  error       String?
  correlationId String   @default(uuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  logs        PipelineLog[]

  @@index([status])
  @@index([type])
  @@index([scheduledAt])
  @@index([correlationId])
}

model PipelineLog {
  id        String    @id @default(uuid())
  jobId     String
  job       PipelineJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  message   String
  level     LogLevel  @default(INFO)
  timestamp DateTime  @default(now())

  @@index([jobId])
  @@index([timestamp])
}

model RecordHash {
  hash      String    @id
  recordId  String
  recordType String
  createdAt DateTime  @default(now())

  @@index([hash])
}